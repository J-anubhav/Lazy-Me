# Copy to .env and fill in. NEVER commit the real .env.

# Gmail OAuth (from `python auth_setup.py`)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Telegram (@BotFather for token, @userinfobot for chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Behavior
DIGEST_TIMEZONE=Asia/Kolkata
BODY_TRUNCATE=500
SEND_ON_EMPTY=true
